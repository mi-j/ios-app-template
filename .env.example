# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- App identity ---
APP_IDENTIFIER=__BUNDLE_ID__
TEAM_ID=__TEAM_ID__
APPLE_ID=__APPLE_ID__
SCHEME=__APP_NAME__

# --- App Store Connect API key ---
ASC_KEY_ID=
ASC_ISSUER_ID=
# base64 of AuthKey_XXXXXXXXXX.p8
# (PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("AuthKey_XXX.p8")))
ASC_KEY_CONTENT=

# --- Fastlane Match (code signing) ---
MATCH_GIT_URL=git@github.com:mi-j/ios-certificates.git
MATCH_PASSWORD=
MATCH_GIT_BASIC_AUTHORIZATION=

# --- Slack notifications (optional) ---
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#ios-builds

# --- Sentry / Mixpanel (optional) ---
SENTRY_DSN=
MIXPANEL_TOKEN=

# --- Supabase staging ---
SUPABASE_URL_STAGING=
SUPABASE_ANON_KEY_STAGING=
SUPABASE_SERVICE_ROLE_KEY_STAGING=
SUPABASE_PROJECT_REF_STAGING=
SUPABASE_DB_PASSWORD_STAGING=

# --- Supabase production (fill when promoting) ---
SUPABASE_URL_PROD=
SUPABASE_ANON_KEY_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=
SUPABASE_PROJECT_REF_PROD=
SUPABASE_DB_PASSWORD_PROD=

# --- Supabase CLI ---
SUPABASE_ACCESS_TOKEN=

# --- AI providers (optional, per app) ---
OPENAI_API_KEY_STAGING=
OPENAI_API_KEY_PROD=
ANTHROPIC_API_KEY_STAGING=
ANTHROPIC_API_KEY_PROD=

# --- RevenueCat webhook (optional) ---
REVENUECAT_WEBHOOK_SECRET_STAGING=
REVENUECAT_WEBHOOK_SECRET_PROD=
