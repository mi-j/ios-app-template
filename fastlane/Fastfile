default_platform(:ios)

# App Store Connect API key setup (avoids 2FA, works in CI)
def load_asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_content: ENV["ASC_KEY_CONTENT"],
    is_key_content_base64: true,
    in_house: false
  )
end

# Demo account credentials for App Review (override per app via env)
def review_information_hash
  {
    first_name: "Review",
    last_name: "Demo",
    phone_number: ENV.fetch("REVIEW_PHONE", "+1 (555) 000-0001"),
    email_address: ENV.fetch("REVIEW_EMAIL", "appreviewer@example.com"),
    demo_user: ENV.fetch("REVIEW_DEMO_USER", "reviewer@example.com"),
    demo_password: ENV.fetch("REVIEW_DEMO_PASSWORD", ""),
    notes: ENV.fetch("REVIEW_NOTES",
      "Sign in with the demo account to explore the full app. " \
      "AI/network features require an internet connection. " \
      "Bypass paywall via the sandbox 'Restore Purchases' flow."
    )
  }
end

def app_scheme
  ENV["SCHEME"] || "__APP_NAME__"
end

def ipa_name
  "#{app_scheme}.ipa"
end

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Run linting (SwiftLint)"
  lane :lint do
    swiftlint(mode: :lint, strict: true, ignore_exit_status: false)
  end

  desc "Run unit tests"
  lane :test do
    run_tests(
      scheme: app_scheme,
      devices: ["iPhone 15"],
      clean: true,
      code_coverage: true,
      output_directory: "fastlane/test_output",
      output_files: "report.junit"
    )
  end

  desc "Run UI tests (XCUITest)"
  lane :ui_test do
    run_tests(
      scheme: ENV["UI_TEST_SCHEME"] || "#{app_scheme}UITests",
      devices: ["iPhone 15"],
      clean: true,
      code_coverage: false,
      output_directory: "fastlane/ui_test_output",
      output_files: "report.junit",
      max_concurrent_simulators: 1,
      result_bundle: true
    )
  end

  desc "Sync code signing certs and profiles (read-only in CI)"
  lane :sync_signing do
    api_key = load_asc_api_key
    match(type: "appstore", readonly: true, api_key: api_key)
  end

  desc "Build and archive the app (no upload)"
  lane :build do
    sync_signing
    build_app(
      scheme: app_scheme,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: ipa_name,
      clean: true
    )
  end

  desc "Build and upload to TestFlight (beta)"
  lane :beta do
    api_key = load_asc_api_key

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M")
    )

    sync_signing
    build_app(
      scheme: app_scheme,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: ipa_name,
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: last_git_commit[:message]
    )

    notify_slack("New TestFlight build uploaded: #{app_scheme}")
  end

  desc "Build, upload binary + metadata to App Store Connect (no review submission)"
  lane :release do
    api_key = load_asc_api_key

    sync_signing
    build_app(
      scheme: app_scheme,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: ipa_name,
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_screenshots: !Dir.exist?("fastlane/screenshots"),
      skip_metadata: !Dir.exist?("fastlane/metadata"),
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      review_information: review_information_hash
    )

    notify_slack("Build uploaded to App Store Connect: #{app_scheme}")
  end

  desc "Submit the latest App Store Connect build for review (use after :release)"
  lane :submit do
    api_key = load_asc_api_key

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "fastlane/metadata",
      review_information: review_information_hash,
      submission_information: {
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false,
        export_compliance_uses_encryption: true,
        export_compliance_encryption_updated: false,
        export_compliance_app_type: nil,
        export_compliance_uses_exempt_encryption: true,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_contains_third_party_cryptography: false,
        export_compliance_available_on_french_store: false,
        export_compliance_platform: "ios"
      }
    )

    notify_slack("#{app_scheme} submitted for App Store review")
  end

  error do |lane, exception, options|
    notify_slack("Fastlane #{lane} failed: #{exception.message}", success: false)
  end

  # ---- helpers --------------------------------------------------------

  def notify_slack(message, success: true)
    slack_url = ENV.fetch("SLACK_WEBHOOK_URL", "").strip
    return if slack_url.empty?
    slack(
      message: message,
      channel: ENV["SLACK_CHANNEL"] || "#ios-builds",
      slack_url: slack_url,
      success: success
    )
  end
end
